###############################################################################
# VeritasSR Makefile
###############################################################################

CXX := g++

TARGET := exprgen

SRC_DIR := src
BUILD_DIR := build
OBJ_DIR := $(BUILD_DIR)/obj

###############################################################################
# Compiler Flags
###############################################################################

CXXFLAGS := -std=c++17 -Wall -Wextra -MMD -MP -Iinclude
DEBUGFLAGS := -g -O0
RELEASEFLAGS := -O3

###############################################################################
# Source Discovery
###############################################################################

SRC := $(shell find $(SRC_DIR) -name "*.cpp")

OBJ := $(patsubst $(SRC_DIR)/%.cpp,$(OBJ_DIR)/%.o,$(SRC))

DEP := $(OBJ:.o=.d)

###############################################################################
# Default Build
###############################################################################

all: release

###############################################################################
# Release
###############################################################################

release: CXXFLAGS += $(RELEASEFLAGS)
release: $(TARGET)

###############################################################################
# Debug
###############################################################################

debug: CXXFLAGS += $(DEBUGFLAGS)
debug: $(TARGET)

###############################################################################
# Link
###############################################################################

$(TARGET): $(OBJ)
	$(CXX) $(OBJ) -o $@

###############################################################################
# Compile
###############################################################################

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

###############################################################################
# Clean
###############################################################################

clean:
	rm -rf $(BUILD_DIR)
	rm -f $(TARGET)

###############################################################################
# Dependencies
###############################################################################

-include $(DEP)

###############################################################################
# Convenience
###############################################################################

run: $(TARGET)
	./$(TARGET)

.PHONY: all release debug clean run
